{
  "name": "adopt-me-value-checker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Lightweight, ad-free Adopt Me pet and item value checker.",
  "scripts": {
    "dev": "vite",
    "dev:netlify": "netlify dev",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "preflight": "tsx scripts/preflight.ts",
    "sync:local": "tsx scripts/runSyncLocal.ts",
    "wipe:local": "tsx scripts/wipeData.ts",
    "verify:data": "tsx scripts/verifyData.ts",
    "dump:catalog": "tsx scripts/dumpCatalog.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.105.4",
    "cheerio": "^1.2.0",
    "fuse.js": "^7.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@netlify/functions": "^5.2.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^6.0.2",
    "ajv": "^8.20.0",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "netlify-cli": "^26.0.2",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
