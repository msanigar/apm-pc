# Public Supabase config (safe for frontend bundle)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase config (Netlify Functions only; never exposed to browser)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Supabase Storage bucket used to cache item/pet images
SUPABASE_IMAGE_BUCKET=adopt-me

# Optional: comma-separated list of enabled source adapter names
# Defaults to all three mock adapters when unset.
VALUE_SOURCE_ADAPTERS=mock-a,mock-b,mock-c
