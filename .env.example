# ─── Supabase ──────────────────────────────────────────────────────────────
# Server-side only — Netlify Functions read these via process.env at runtime.
# The browser never talks to Supabase directly; it goes through the
# /api/* functions. So we DON'T expose VITE_SUPABASE_* to the client bundle.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Bypasses RLS — TRULY secret. In Netlify UI, mark this one (and only this
# one) as "contains secret values". See netlify.toml for the SECRETS_SCAN_OMIT_KEYS
# list of the others, which are safe to scan-omit.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: Supabase Storage bucket used to cache item/pet images
SUPABASE_IMAGE_BUCKET=adopt-me

# ─── Adapter selection ────────────────────────────────────────────────────
# Unset → enable all adapters that are turned on via the ENABLE_* flags below
#         (plus the always-on mock adapters).
# "mock-only" → just the three mock adapters; ignore ENABLE_* flags.
# Comma-separated list of names → only those adapters.
# VALUE_SOURCE_ADAPTERS=mock-only

# ─── Real source adapters (default off; flip on per source after ToS check) ─
# ENABLE_AMVERSE=1                  # amverse.co — Elvebredd values via JSON API
# ENABLE_ADOPT_ME_TRADING_VALUES=1  # adoptmetradingvalues.org/values
# ENABLE_AMTV_LEGACY_MIRROR=1       # also pull adoptmetradingvalues.com
# ENABLE_GITHUB_DATASET=1           # shabbl3/gizmo.values (embedded pets array)
# ENABLE_GITHUB_IRONBABA=1          # ironbabatekkral/adoptme-values (placeholder)
# ENABLE_GITHUB_HIGH_TIER=1         # Roblox-Services high-tier pets fallback
